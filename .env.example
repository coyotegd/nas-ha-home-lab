# .env.example — Copy to .env and fill in your values
#
# These values are referenced in the README. Some are used by
# docker-compose.yml (marked [compose]). The rest are a checklist
# of site-specific settings you'll need to configure.

# ── Network ──────────────────────────────────────────────

# [compose] Your NAS IP on the local network
NAS_IP=192.168.1.x

# Your domain (managed in Cloudflare)
DOMAIN=yourdomain.com

# ── Timezone ─────────────────────────────────────────────

# [compose] Timezone for HA, ESPHome, Z-Wave JS UI
TZ=America/New_York

# ── Cloudflare ───────────────────────────────────────────

# Cloudflare API token (used in NPM for DNS challenge SSL certs)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone > DNS > Edit
CLOUDFLARE_API_TOKEN=your-token-here

# ── Z-Wave JS UI ─────────────────────────────────────────

# [compose] Session secret for Z-Wave JS UI (generate: openssl rand -hex 32)
ZWAVEJS_SESSION_SECRET=generate-with-openssl-rand-hex-32

# ── Device IPs ───────────────────────────────────────────

# Zigbee coordinator (SLZB-06MU) IP
ZIGBEE_COORDINATOR_IP=192.168.1.x

# Z-Wave coordinator (TubesZB) IP
ZWAVE_COORDINATOR_IP=192.168.1.x

# GL-S200 Thread Border Router IP
S200_IP=192.168.1.x

# ── Odroid SBCs ──────────────────────────────────────────

# Odroid #1 (Network Core) IP
ODROID1_IP=192.168.1.x

# Odroid #2 (Media Server) IP
ODROID2_IP=192.168.1.x

# ── GL-S200 Credentials (for TDB bridge scripts) ────────

# S200 login user (usually root)
S200_USER=root

# S200 crypt password hash (openssl passwd -1 -salt "YOUR_SALT" "YOUR_PASSWORD")
S200_CRYPT_PW=$1$salt$hash

# ── Odroid Services ──────────────────────────────────────

# Vaultwarden admin token (generate: openssl rand -base64 48)
VW_ADMIN_TOKEN=generate-with-openssl-rand-base64-48

# Beszel hub key (from Beszel UI when adding an agent)
BESZEL_KEY=your-beszel-key
